# Kanboard connection (required)
# URL of the self-hosted Kanboard instance. Must be reachable.
KANBOARD_URL=https://kanboard.example.com/

# Kanboard API token. Generate from Kanboard: Profile > API access > Token.
# Required in both auth modes. Treat this as a secret — never commit the real value.
KANBOARD_API_TOKEN=your-api-token-here

# ---------------------------------------------------------------------------
# Auth mode (optional — defaults to "personal")
# ---------------------------------------------------------------------------

# Authentication mode: "personal" (default) or "app".
# personal: authenticates as your specific Kanboard user (uses KANBOARD_USERNAME + KANBOARD_API_TOKEN).
# app:      authenticates as the built-in app user (uses only KANBOARD_API_TOKEN).
KANBOARD_AUTH_MODE=personal

# Your Kanboard login username.
# Required when KANBOARD_AUTH_MODE=personal. Not used in "app" mode.
KANBOARD_USERNAME=your-kanboard-username

# ---------------------------------------------------------------------------
# Runtime tuning (optional — sensible defaults applied when unset)
# ---------------------------------------------------------------------------

# Log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# HTTP request timeout to Kanboard in milliseconds.
# Default: 15000
KANBOARD_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Integration tests (required only when running `npm run test:int`)
# ---------------------------------------------------------------------------

# ID of a dedicated Kanboard project used exclusively for integration tests.
# The project name MUST contain "sandbox" or "test".
# The integration harness refuses to run if this variable is empty.
# Never point this at a real project — test data is written and read during each run.
KANBOARD_TEST_PROJECT_ID=

# Set to `1` to enable integration tests. Any other value (or unset) skips them.
# Unit tests always run regardless of this flag.
RUN_INTEGRATION=0
